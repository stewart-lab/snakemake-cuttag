QUARTO_HTML_FILES = [os.path.dirname(f) + "/output/" + os.path.splitext(os.path.basename(f))[0] + ".html" for f in QMD_FILES]


# ********** helpers for fastp **********
def get_r1(wildcards):
    return os.path.normpath(os.path.join(CONFIG_DIR, samples_df.loc[wildcards.sample, "r1"]))

def get_r2(wildcards):
    return os.path.normpath(os.path.join(CONFIG_DIR, samples_df.loc[wildcards.sample, "r2"]))

# ********** helpers for dropping samples **********
def get_excluded_samples():
    """All samples listed in the exclude table, de-duplicated."""
    return EXCLUDE["sample"].dropna().astype(str).drop_duplicates().tolist()

# ********** helpers for gopeaks **********
def get_target_bam(wildcards):
    return f"{STEP_FILTERED_READS_DIR}{SAMPLE_MARK[wildcards.sample]}/{wildcards.sample}.filtered.bam"

def get_igg_control_bam(wildcards):
    igg = IGG_CONTROL.get(wildcards.sample)
    if igg is None:
        raise ValueError(f"No IgG control mapped for sample {wildcards.sample!r} in igg_controls.csv")
    return f"{STEP_FILTERED_READS_DIR}{SAMPLE_MARK[igg]}/{igg}.filtered.bam"

def gopeaks_broad_flag(wildcards):
    # see https://github.com/maxsonBraunLab/gopeaks , "Recommended parameters" section
    return "--broad --mdist 3000" if SAMPLE_MARK[wildcards.sample] in BROAD_MARKS else ""



############# rule all #############
rule all:
    input:
        STEP_MULTIQC_DIR + "multiqc_report.html",

############# Step 1: Fastp trimming #############
rule fastp_trim:
    input:
        r1=get_r1,
        r2=get_r2,
    output:
        r1=STEP_FASTP_DIR + "{mark}/{sample}_R1.fastq",
        r2=STEP_FASTP_DIR + "{mark}/{sample}_R2.fastq",
        html=STEP_FASTP_DIR + "{mark}/{sample}.fastp.html",
        json=STEP_FASTP_DIR + "{mark}/{sample}.fastp.json",
    conda:
        "envs/fastp.yml"
    threads:
        1
    log:
        LOGS + Path(STEP_FASTP_DIR).name + "/{mark}/{sample}.log"
    shell:
        """
        fastp \
            --in1 {input.r1} \
            --in2 {input.r2} \
            --out1 {output.r1} \
            --out2 {output.r2} \
            --html {output.html} \
            --json {output.json} \
            --thread {threads} \
            --detect_adapter_for_pe \
            &> {log}
        """

############# Step 2: FastQC of trimmed reads #############
rule fastqc:
    input:
        r1=STEP_FASTP_DIR + "{mark}/{sample}_R1.fastq",
        r2=STEP_FASTP_DIR + "{mark}/{sample}_R2.fastq",
    output:
        r1_html=STEP_FASTQC_POST_TRIM_DIR + "{mark}/{sample}_R1_fastqc.html",
        r1_zip=STEP_FASTQC_POST_TRIM_DIR + "{mark}/{sample}_R1_fastqc.zip",
        r2_html=STEP_FASTQC_POST_TRIM_DIR + "{mark}/{sample}_R2_fastqc.html",
        r2_zip=STEP_FASTQC_POST_TRIM_DIR + "{mark}/{sample}_R2_fastqc.zip",
    params:
        outdir=STEP_FASTQC_POST_TRIM_DIR + "{mark}"
    threads:
        2  # FastQC uses one thread per input file (R1, R2); more is wasted
    conda:
        "envs/fastqc.yml"
    log:
        LOGS + Path(STEP_FASTQC_POST_TRIM_DIR).name + "/{mark}/{sample}.log"
    shell:
        """
        mkdir -p {params.outdir}
        fastqc -o {params.outdir} --threads {threads} {input.r1} {input.r2} &> {log}
        """

############# Step 3: Alignment with bowtie2 #############

# Prepare bowtie2 reference
rule bowtie2_prepare_reference:
    input:
        fasta=GENOME_FASTA,
    output:
        idx=multiext(
            STEP_BOWTIE2_REFERENCE_DIR + "bowtie2_reference",
            ".1.bt2l", ".2.bt2l", ".3.bt2l", ".4.bt2l", ".rev.1.bt2l", ".rev.2.bt2l",
        ),
    params:
        ref_prefix=STEP_BOWTIE2_REFERENCE_DIR + "bowtie2_reference",
    threads:
        CORES
    conda:
        "envs/bowtie2.yml"
    log:
        LOGS + Path(STEP_BOWTIE2_DIR).name + "/bowtie2_prepare_reference/prepare.log"
    shell:
        """
        bowtie2-build \
            --large-index \
            --threads {threads} \
            {input.fasta} \
            {params.ref_prefix} \
            &> {log}
        """

# perform the alignment
rule bowtie2_align:
    input:
        r1=STEP_FASTP_DIR + "{mark}/{sample}_R1.fastq",
        r2=STEP_FASTP_DIR + "{mark}/{sample}_R2.fastq",
        idx=multiext(
            STEP_BOWTIE2_REFERENCE_DIR + "bowtie2_reference",
            ".1.bt2l", ".2.bt2l", ".3.bt2l", ".4.bt2l", ".rev.1.bt2l", ".rev.2.bt2l",
        ),
    output:
        bam=STEP_BOWTIE2_DIR + "{mark}/{sample}.sorted.bam",
        bai=STEP_BOWTIE2_DIR + "{mark}/{sample}.sorted.bam.bai",
        summary=STEP_BOWTIE2_DIR + "{mark}/{sample}.bowtie2.log",
        sam=temp(STEP_BOWTIE2_DIR + "{mark}/{sample}.sam"),
    params:
        ref_prefix=STEP_BOWTIE2_REFERENCE_DIR + "bowtie2_reference",
    threads:
        CORES
    conda:
        "envs/bowtie2.yml"
    log:
        LOGS + Path(STEP_BOWTIE2_DIR).name + "/{mark}/{sample}.log"
    shell:
        """
        # run bowtie2 (outputs to .sam)
        bowtie2 \
            --end-to-end \
            --very-sensitive \
            --no-mixed \
            --no-discordant \
            --phred33 \
            -I 10 \
            -X 700 \
            -p {threads} \
            -x {params.ref_prefix} \
            -1 {input.r1} -2 {input.r2} \
            -S {output.sam} \
            &> {log}

        # convert .sam to .bam and sort the reads
        samtools sort -@ {threads} -o {output.bam} {output.sam}

        # index the .bam
        samtools index {output.bam}

        # copy the log file to output dir for MultiQC report
        cp {log} {output.summary}
        """

############# Removing duplicate reads could go here. might be good for samples with >20% duplication. #############

############# Step 4: Filter by mapping quality, proper pairs, fragment length #############
rule samtools_filter_reads:
    input:
        bam=STEP_BOWTIE2_DIR + "{mark}/{sample}.sorted.bam",
        bai=STEP_BOWTIE2_DIR + "{mark}/{sample}.sorted.bam.bai",
    output:
        bam=STEP_FILTERED_READS_DIR + "{mark}/{sample}.filtered.bam",
        bai=STEP_FILTERED_READS_DIR + "{mark}/{sample}.filtered.bam.bai",
    params:
        min_q=2,
        max_frag=1000,
    conda:
        "envs/bowtie2.yml"
    log:
        LOGS + Path(STEP_FILTERED_READS_DIR).name + "/{mark}/{sample}.log",
    shell:
        """
        # -f 0x2                              -- properly paired (both mates mapped, correct orientation)
        # -q                                  -- minimum MAPQ quality
        # -e tlen ...                         -- only keeps inserts < max_frag length

        samtools view \
            --bam \
            -f 0x2 \
            -q {params.min_q} \
            -e 'tlen > -{params.max_frag} && tlen < {params.max_frag}' \
            --threads 1 \
            --output {output.bam} \
            {input.bam} \
            &> {log}

        samtools index {output.bam} &>> {log}
        """

############# Step 5: Peak detection with GoPeaks #############
rule gopeaks:
    input:
        bam=get_target_bam,
        control=get_igg_control_bam,
    output:
        peaks=STEP_GOPEAKS_DIR + "{mark}/{sample}_peaks.bed",
        json=STEP_GOPEAKS_DIR + "{mark}/{sample}_gopeaks.json",
    params:
        prefix=STEP_GOPEAKS_DIR + "{mark}/{sample}",
        broad=gopeaks_broad_flag,
    conda:
        "envs/gopeaks.yml"
    log:
        LOGS + Path(STEP_GOPEAKS_DIR).name + "/{mark}/{sample}.log",
    shell:
        """
        gopeaks \
            --bam {input.bam} \
            --control {input.control} \
            --prefix {params.prefix} \
            {params.broad} \
            &> {log}
        """

############# Step 6: Generate MultiQC report #############
rule multiqc:
    input:
        fastp=expand(
            STEP_FASTP_DIR + "{mark}/{sample}_R1.fastq",
            zip,
            mark=[SAMPLE_MARK[s] for s in SAMPLES],
            sample=SAMPLES,
        ),
        fastqc=expand(
            STEP_FASTQC_POST_TRIM_DIR + "{mark}/{sample}_R1_fastqc.html",
            zip,
            mark=[SAMPLE_MARK[s] for s in SAMPLES],
            sample=SAMPLES,
        ),
        bowtie2=expand(
            STEP_BOWTIE2_DIR + "{mark}/{sample}.bowtie2.log",
            zip,
            mark=[SAMPLE_MARK[s] for s in SAMPLES],
            sample=SAMPLES,
        ),
        gopeaks=expand(
            STEP_GOPEAKS_DIR + "{mark}/{sample}_gopeaks.json",
            zip,
            mark=[SAMPLE_MARK[s] for s in PEAK_SAMPLES],
            sample=PEAK_SAMPLES,
        ),
    output:
        html=STEP_MULTIQC_DIR + "multiqc_report.html",
    params:
        scan_dirs=" ".join([
            STEP_FASTP_DIR,
            STEP_FASTQC_POST_TRIM_DIR,
            STEP_BOWTIE2_DIR,
            STEP_GOPEAKS_DIR,
        ]),
        outdir=STEP_MULTIQC_DIR,
    conda:
        "envs/multiqc.yml"
    log:
        LOGS + Path(STEP_MULTIQC_DIR).name + "/multiqc.log",
    shell:
        """
        multiqc \
            --force \
            --outdir {params.outdir} \
            --filename multiqc_report.html \
            {params.scan_dirs} \
            &> {log}
        """



