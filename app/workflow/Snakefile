# ********** directories for built references **********
STEP_BOWTIE2_REFERENCE_DIR =    GENOME_DIR + "bowtie2_reference/"

# ********** read samples/contrasts **********
samples_df = pd.read_csv(SAMPLESHEET_CSV_PATH).set_index("sample", drop=False)
SAMPLES = samples_df["sample"].tolist()
SAMPLE_MARK = samples_df["mark"].to_dict()

CONTRASTS = pd.read_csv(CONTRASTS_CSV_PATH)
CONTRAST_NAMES = [
    f"{row.treatment}_vs_{row.control}"
    for row in CONTRASTS.itertuples()
]

# ********** genome info **********
# The reference FASTA and GTF are auto-detected from the genome_dir, which must
# contain exactly one FASTA (.fa/.fasta/.fna) and exactly one GTF (.gtf).
def _get_reference_file(directory, extensions, label):
    matches = sorted({
        f
        for ext in extensions
        for f in glob(os.path.join(directory, "*" + ext))
    })
    if len(matches) != 1:
        raise ValueError(
            f"Expected exactly one {label} file in genome_dir '{directory}', "
            f"but found {len(matches)}: {matches or 'none'}"
        )
    return matches[0]

GENOME_FASTA = _get_reference_file(GENOME_DIR, (".fa", ".fasta", ".fna"), "FASTA (.fa/.fasta/.fna)")
GTF = _get_reference_file(GENOME_DIR, (".gtf",), "GTF (.gtf)")




IGG_CONTROL = (
    pd.read_csv(IGG_CONTROLS_CSV_PATH).set_index("sample")["igg_control"].to_dict()
)

# Marks that should be called in --broad mode in GoPeaks
# TODO: move to .csv or config.yml
BROAD_MARKS = {"H3K4me1", "H3K27ac", "H3K27me3"}

# targets are everything we actually call peaks on (i.e., exclude IgG samples)
# TODO: don't hardcode IgG here
PEAK_SAMPLES = [s for s in SAMPLES if SAMPLE_MARK[s] != "IgG"]

DESEQ_SYMBOL_FILES = ["normalized_counts"] + CONTRAST_NAMES # i.e., excludes size factor .csv
CONTROL_CONDITIONS = sorted(CONTRASTS["control"].unique().tolist())

# samples to drop
